{
  "name": "jest-testing",
  "version": "1.0.0",
  "description": "Домашнее задание 7.3",
  "main": "app.js",
  "scripts": {
    "test": "jest",
    "coverage": "jest --collectCoverage"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "collectCoverageFrom":[
      "**/*.{js,jsx}",
      "!**/node_modules/**",
      "!**/coverage/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 100,
        "functions": 100,
        "lines": 100
      }
    }
  }
}